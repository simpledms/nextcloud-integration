<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
  <id>simpledms_integration</id>
  <name>SimpleDMS integration</name>
  <summary>SimpleDMS integration to upload files from Nextcloud to SimpleDMS</summary>
  <description lang="en"><![CDATA[
[SimpleDMS](https://simpledms.eu) integration that adds a files context menu action to upload a file from Nextcloud to SimpleDMS.
]]>
  </description>
  <description lang="de"><![CDATA[
[SimpleDMS](https://simpledms.eu)-Integration, die ein Datei-Kontextmenü zum Hochladen von Dateien aus Nextcloud zu SimpleDMS hinzufügt.
]]>
  </description>
  <version>1.0.0</version>
  <licence>AGPL-3.0-only</licence>
  <author homepage="https://www.marcobeierer.ch">Marco Beierer</author>
  <namespace>SimpleDMS</namespace>
  <category>integration</category>
  <website>https://simpledms.eu</website>
  <bugs>https://github.com/simpledms/simpledms-nextcloud/issues</bugs>
  <repository>https://github.com/simpledms/simpledms-nextcloud</repository>
  <screenshot small-thumbnail="https://simpledms.eu/assets/simpledms/screenshots/2026.03.20-screenshot-dateien_details-1024x576.png">https://simpledms.eu/assets/simpledms/screenshots/2026.03.20-screenshot-dateien_details.png</screenshot>

  <types>
    <filesystem/>
  </types>

  <dependencies>
    <nextcloud min-version="32" max-version="33"/>
  </dependencies>

  <settings>
    <admin>OCA\SimpleDMS\Settings\Admin</admin>
  </settings>
</info>
